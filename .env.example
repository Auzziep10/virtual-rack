# ==========================================
# The Virtual Rack - Environment Configuration
# ==========================================

# ------------------------------------------
# DATABASE (Prisma / Supabase PostgreSQL)
# ------------------------------------------
# Find this in your Supabase Dashboard -> Project Settings -> Database -> Connection string (URI)
# Ensure you append "?pgbouncer=true&connection_limit=1" if using the transaction pooler.
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Used for direct database connections (e.g., Prisma Migrations)
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"


# ------------------------------------------
# WEB APP (Next.js & Supabase Client)
# ------------------------------------------
# Used by the web app client to securely interface with Supabase Auth and Storage.
# Find these in Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."


# ------------------------------------------
# FIREBASE (3D Asset Storage)
# ------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY="your_api_key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your_project"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your_project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
NEXT_PUBLIC_FIREBASE_APP_ID="your_app_id"

# ------------------------------------------
# VTO DRAPE SIMULATION BACKEND
# ------------------------------------------
# Authentication key for the external GPU compute worker (RunPod, Replicate, Custom FastAPI)
SIMULATION_API_KEY="your_secure_gpu_worker_api_key_here"
